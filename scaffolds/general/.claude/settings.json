{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(ls:*)",
      "Read(./**)"
    ],
    "deny": [
      "Read(./.env*)",
      "Read(./**/secrets/**)",
      "Bash(rm -rf:*)"
    ]
  }
}
